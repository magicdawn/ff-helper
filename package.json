{
  "name": "ff-helper",
  "version": "0.6.2",
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "description": "ffmpeg helper by napi-rs binding",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/ff-helper#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/ff-helper.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/ff-helper/issues"
  },
  "keywords": [
    "ffmpeg",
    "ffprobe",
    "napi",
    "napi-rs",
    "video-info",
    "video-rotation",
    "video-duration"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "./ff-helper.*.node",
    "CHANGELOG.md",
    "Cargo.lock",
    "Cargo.toml",
    "LICENSE",
    "README.md",
    "addon.d.ts",
    "addon.js",
    "build.rs",
    "lib",
    "package.json",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepare": "husky",
    "build:debug": "napi build --platform --js addon.js --dts addon.d.ts",
    "build:release": "napi build --platform --js addon.js --dts addon.d.ts --release",
    "dev": "pnpm build:debug",
    "build:tsc": "rm -rf lib; tsc",
    "build": "pnpm build:release && pnpm test && pnpm build:tsc",
    "prepublishOnly": "pnpm build",
    "install": "pnpm build-addon-when-necessary",
    "build-addon-when-necessary": "(node ./addon.js > /dev/null 2>&1) || pnpm build:release",
    "test": "vitest run",
    "test-cover": "vitest run --coverage",
    "_prepublishOnly": "napi prepublish -t npm",
    "_artifacts": "napi artifacts",
    "_universal": "napi universal",
    "_version": "napi version"
  },
  "dependencies": {
    "@napi-rs/cli": "^3.5.1",
    "dayjs": "^1.11.19"
  },
  "devDependencies": {
    "@magicdawn/eslint-config": "^1.6.1",
    "@magicdawn/prettier-config": "^0.1.0",
    "@swc/core": "^1.15.11",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "4.0.18",
    "dl-vampire": "^2.1.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "napi": {
    "binaryName": "ff-helper",
    "package": {},
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "lint-staged": {
    "*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
